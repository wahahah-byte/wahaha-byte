{
  "name": "wahaha-byte",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "web": "npm --workspace @wahaha/web run dev",
    "web:build": "npm --workspace @wahaha/web run build",
