{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/recurring/layout,_N_T_/recurring/page,_N_T_/recurring"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/recurring/__PAGE__",
    "/recurring",
    "/_index",
    "/_head"
  ]
}