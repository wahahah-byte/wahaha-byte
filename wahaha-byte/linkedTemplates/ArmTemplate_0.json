						"container": "input"
					},
					"columnDelimiter": ",",
					"escapeChar": "\\",
					"firstRowAsHeader": true,
					"quoteChar": "\""
				},
				"schema": [
					{
						"name": "item_id",
						"type": "String"
					},
					{
						"name": "name",
						"type": "String"
					},
					{
						"name": "category",
						"type": "String"
					},
					{
						"name": "slot",
						"type": "String"
					},
					{
						"name": "rarity",
						"type": "String"
					},
					{
						"name": "cost",
						"type": "String"
					},
					{
						"name": "description",
