{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "wahaha-byte"
		},
		"Blob To CSV_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'Blob To CSV'"
		},
		"OutputSQL_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'OutputSQL'"
		},
		"OutputSQL_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "wahaha.database.windows.net"
		},
		"OutputSQL_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "wahaha-db"
		},
		"OutputSQL_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "byte-admin"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "[concat(parameters('factoryName'), '/Blob To CSV')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureBlobStorage",
				"typeProperties": {
					"connectionString": "[parameters('Blob To CSV_connectionString')]"
				}
			},
			"dependsOn": []
		},
		{
			"name": "[concat(parameters('factoryName'), '/OutputSQL')]",
			"type": "Microsoft.DataFactory/factories/linkedServices",
			"apiVersion": "2018-06-01",
			"properties": {
				"annotations": [],
				"type": "AzureSqlDatabase",
				"typeProperties": {
					"server": "[parameters('OutputSQL_properties_typeProperties_server')]",
					"database": "[parameters('OutputSQL_properties_typeProperties_database')]",
					"encrypt": "mandatory",
					"trustServerCertificate": false,
					"authenticationType": "SQL",
					"userName": "[parameters('OutputSQL_properties_typeProperties_userName')]",
					"password": {
						"type": "SecureString",
						"value": "[parameters('OutputSQL_password')]"
					}
				}
			},
			"dependsOn": []
		},
